# ─────────────────────────────────────────────────────────────
# DataGrid Backend — environment variables template
# ─────────────────────────────────────────────────────────────
# Copy this file to .env and fill in real values.
# .env is gitignored — never commit it.

# ─── Server ──────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
WS_PORT=4001

# ─── Database ────────────────────────────────────────────────
# Main Postgres connection (used for all queries)
DATABASE_URL=postgresql://your_user@localhost:5432/datagriid_db

# Optional read-only Postgres connection (used for AI SQL queries)
# If not set, the app falls back to the main DATABASE_URL.
# In production, set this to a Postgres role with only SELECT permissions.
# DATABASE_URL_READONLY=postgresql://readonly_user:password@host:5432/datagriid_db

# ─── OpenAI ──────────────────────────────────────────────────
# Get your key at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your_openai_key_here

# ─── CORS ────────────────────────────────────────────────────
# Comma-separated list of allowed origins, or * for all
CORS_ORIGIN=http://localhost:5173

# ─── Anomaly detection ───────────────────────────────────────
# How often (in ms) to scan pipelines for issues. Set to 0 to disable.
ANOMALY_INTERVAL_MS=60000
